# ---- Database ----
# Local development (Drizzle + node-postgres):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db
# Neon (production) — paste your Neon connection string here:
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# ---- Auth ----
# Secret used to sign JWT admin sessions. Generate a strong random string:
#   openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret-string

# ---- Auto-Seeding (Optional) ----
# Set to "true" to DISABLE automatic seeding of sample products/categories
# on every homepage visit. Tables and admin account will still be created
# (needed for the site to work), but no demo data will be inserted.
#
# When to use:
# - You want to start with empty tables and add products manually
# - You've deleted tables in Neon and don't want them re-seeded automatically
# - You want full control over what data exists
#
# When to keep as false (or delete this line):
# - Fresh deployment where you want demo products to show immediately
# - Testing / development
#
# Values: true | false | 1 | 0 | yes | no
DISABLE_AUTO_SEED=false

# ---- Public ----
# Absolute site URL (used for metadata / absolute links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
